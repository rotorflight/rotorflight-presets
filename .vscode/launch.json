{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "1. Run Indexer",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/indexer/indexer.js",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "2. Check Presets",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/indexer/check.js",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
    ]
}